    "generate:maploadouts": "node scripts/generate-game-map-loadout-pages.mjs",
    "generate:tools": "node scripts/generate-tools-page.mjs",
    "generate:blog": "node scripts/generate-blog-posts.mjs",
    "generate:guides": "node scripts/generate-guides.mjs",
